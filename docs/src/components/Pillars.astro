---
interface PillarItem {
  icon: 'semantics' | 'no-gen' | 'no-cycle' | 'no-blackbox';
  title: string;
  desc: string;
  code?: string;
}

interface Props {
  items: PillarItem[];
}

const { items } = Astro.props;

const icons: Record<PillarItem['icon'], string> = {
  semantics:
    '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="M8 10h8M8 13.5h5"/>',
  'no-gen': '<path d="M13 2 4.5 13.5H11l-1 8.5 8.5-11.5H12l1-8.5z"/>',
  'no-cycle': '<path d="M9 17H7a5 5 0 0 1 0-10h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8"/>',
  'no-blackbox': '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
};

// Tiny Go-ish highlighter. Uses stashing with a NUL delimiter so injected
// markup (and bare numbers like 100) are never re-processed.
function highlight(code: string): string {
  let s = code.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const store: string[] = [];
  const stash = (cls: string, txt: string) => {
    store.push(`<span class="${cls}">${txt}</span>`);
    return `\x00${store.length - 1}\x00`;
  };
  s = s.replace(/\/\/.*$/gm, (m) => stash('tok-com', m));
  s = s.replace(/&quot;.*?&quot;|"[^"]*"/g, (m) => stash('tok-str', m));
  s = s.replace(
    /\b(Field|db|Use|Table|Raw|With|Where|Get|First|One|Debug|Eq|NotEq|Gt|Gte|Lt|Lte|In|NotIn|Like|NotLike|Between|IsNull|IsNotNull)\b/g,
    '<span class="tok-fn">$1</span>'
  );
  s = s.replace(/\[([A-Z][A-Za-z0-9]*)\]/g, '[<span class="tok-key">$1</span>]');
  s = s.replace(/\x00(\d+)\x00/g, (_, i) => store[Number(i)]);
  return s;
}
---
<div class="mt-9 grid gap-4 md:grid-cols-2">
  {items.map((item) => (
    <article class="flex h-full flex-col rounded-2xl bg-surface p-7 transition hover:-translate-y-0.5 hover:shadow-[var(--dux-shadow)]">
      <span
        class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-ink text-canvas"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          set:html={icons[item.icon]}
        />
      </span>
      <h3 class="mb-2 text-[1.18rem] font-bold tracking-[-0.02em] text-ink">{item.title}</h3>
      <p class="mb-5 text-[0.95rem] leading-relaxed text-muted">{item.desc}</p>
      {item.code && (
        <code
          class="dux-code-dark mt-auto block overflow-x-auto whitespace-pre rounded-lg px-3.5 py-3 font-mono text-[0.8rem] leading-normal"
          set:html={highlight(item.code)}
        />
      )}
    </article>
  ))}
</div>
