---
interface Props {
  target?: string;
}
const { target = '/zh-cn/' } = Astro.props;
---
<script is:inline define:vars={{ target }}>
  (() => {
    const key = 'oro:language-redirected';
    const path = window.location.pathname;
    const isRoot = path === '/' || path === '';
    if (!isRoot || window.sessionStorage.getItem(key)) return;
    const languages =
      navigator.languages && navigator.languages.length
        ? navigator.languages
        : [navigator.language];
    const prefersChinese = languages.some((lang) => /^zh/i.test(lang || ''));
    if (!prefersChinese) return;
    window.sessionStorage.setItem(key, '1');
    window.location.replace(target);
  })();
</script>
