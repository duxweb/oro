---
import context from 'virtual:starlight/project-context';
import config from 'virtual:starlight/user-config';

function localizedPathname(locale: string | undefined): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const pathname = Astro.url.pathname;
  const currentLocale = Astro.locals.starlightRoute.locale;
  const defaultLocale = config.defaultLocale.locale;
  const localePrefix = currentLocale === defaultLocale ? '' : `/${currentLocale}`;
  const withoutBase = base && pathname.startsWith(base) ? pathname.slice(base.length) || '/' : pathname;
  const withoutLocale =
    localePrefix && withoutBase.startsWith(`${localePrefix}/`)
      ? withoutBase.slice(localePrefix.length)
      : localePrefix && withoutBase === localePrefix
        ? '/'
        : withoutBase;
  const nextPrefix = locale === defaultLocale ? '' : `/${locale}`;
  const nextPath = `${base}${nextPrefix}${withoutLocale.startsWith('/') ? withoutLocale : `/${withoutLocale}`}`;
  return context.trailingSlash === 'never' && nextPath !== '/' ? nextPath.replace(/\/$/, '') : nextPath;
}

const isMultilingual = config.isMultilingual;
const currentLocale = Astro.locals.starlightRoute.locale;
const current = Object.entries(config.locales).find(([code]) => code === currentLocale)?.[1]?.label ?? 'Language';
const accessibleLabel = Astro.locals.t('languageSelect.accessibleLabel');
const options = Object.entries(config.locales).map(([code, locale]) => ({
  href: localizedPathname(code),
  selected: code === currentLocale,
  label: locale!.label,
}));
---

{isMultilingual && (
  <starlight-lang-select class="dux-menu" data-menu-kind="language">
    <button class="dux-menu__trigger" type="button" aria-haspopup="menu" aria-expanded="false" aria-label={accessibleLabel}>
      <span class="dux-menu__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h9M9 3v2M11 5c-.7 3.9-2.8 6.9-6 9M6 9c1.2 2.1 3 3.9 5.3 5.2"/><path d="M13 21l5-11 5 11M15 17h6"/></svg>
      </span>
      <span class="dux-menu__label">{current}</span>
      <span class="dux-menu__caret" aria-hidden="true">▾</span>
    </button>
    <div class="dux-menu__panel" role="menu" aria-label={accessibleLabel}>
      {options.map((option) => (
        <a href={option.href} role="menuitemradio" aria-checked={option.selected ? 'true' : 'false'}>
          <span class="dux-menu__mark" aria-hidden="true"></span>
          <span>{option.label}</span>
        </a>
      ))}
    </div>
  </starlight-lang-select>
)}

<script is:inline>
  (() => {
    const closeAll = () => {
      document.querySelectorAll('starlight-lang-select[data-open="true"]').forEach((menu) => {
        menu.dataset.open = 'false';
        menu.querySelector('.dux-menu__trigger')?.setAttribute('aria-expanded', 'false');
      });
    };
    class OroLanguageSelect extends HTMLElement {
      connectedCallback() {
        if (this.dataset.ready === 'true') return;
        this.dataset.ready = 'true';
        const trigger = this.querySelector('.dux-menu__trigger');
        trigger?.addEventListener('click', (event) => {
          event.stopPropagation();
          const willOpen = this.dataset.open !== 'true';
          closeAll();
          this.dataset.open = willOpen ? 'true' : 'false';
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      }
    }
    if (!customElements.get('starlight-lang-select')) customElements.define('starlight-lang-select', OroLanguageSelect);
    document.addEventListener('click', closeAll);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAll();
    });
  })();
</script>
