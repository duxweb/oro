---
const { starlightRoute } = Astro.locals;
const { entry, lang } = starlightRoute;
const hero = entry.data.hero;
const isZh = (lang || '').toLowerCase().startsWith('zh');

const eyebrow = 'Oro ORM';
const installCmd = 'go get github.com/duxweb/oro';
const fileName = 'product.go';

const code = isZh
  ? `// 模型就是普通的 Go struct
type Product struct {
    oro.Model
    Code  string
    Price uint
}

// 像说话一样写条件
list, _ := db.Use[Product]().
    Where(
        oro.Field("Price").Gte(100),
        oro.Field("Code").Like("P%"),
    ).
    Get(ctx)`
  : `// a model is just a plain Go struct
type Product struct {
    oro.Model
    Code  string
    Price uint
}

// write conditions the way you'd say them
list, _ := db.Use[Product]().
    Where(
        oro.Field("Price").Gte(100),
        oro.Field("Code").Like("P%"),
    ).
    Get(ctx)`;

// Small, dependency-free Go highlighter (Starlight disables Astro's Shiki bundle).
// Stash matched spans behind NUL markers so injected markup / bare numbers
// are never re-processed.
function highlight(src: string): string {
  let s = src.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const store: string[] = [];
  const stash = (cls: string, txt: string) => {
    store.push(`<span class="${cls}">${txt}</span>`);
    return `\x00${store.length - 1}\x00`;
  };
  s = s.replace(/\/\/[^\n]*/g, (m) => stash('tok-com', m));
  s = s.replace(/&quot;.*?&quot;|"[^"]*"/g, (m) => stash('tok-str', m));
  s = s.replace(/\b(type|func|struct|string|uint|int|bool|return)\b/g, '<span class="tok-key">$1</span>');
  s = s.replace(
    /\b(oro|db|Use|Where|First|Field|Define|Register|Sync|Create|Model|SchemaBuilder|String|Uint|Default|Unique|Table|Get|Debug|Eq|NotEq|Gt|Gte|Lt|Lte|In|NotIn|Like|NotLike|Between|IsNull|IsNotNull)\b/g,
    '<span class="tok-fn">$1</span>'
  );
  s = s.replace(/\x00(\d+)\x00/g, (_, i) => store[Number(i)]);
  return s;
}

const title = hero?.title ?? entry.data.title;
const tagline = hero?.tagline ?? '';
const actions = hero?.actions ?? [];
const pills = isZh
  ? ['人性化语义', '零代码生成', '无循环依赖', '非黑盒']
  : ['Humane semantics', 'No codegen', 'No import cycle', 'No black box'];
---

<div class="pb-10 pt-4 md:pb-16 md:pt-10">
  <div class="mx-auto max-w-3xl text-center">
    <p class="mb-5 font-mono text-[1.5rem] font-bold tracking-[0.06em] text-ink">{eyebrow}</p>
    <h1
      class="m-0 bg-linear-to-r from-ink via-ink to-accent bg-clip-text text-[clamp(2rem,4vw,2.5rem)] font-extrabold leading-[1.15] tracking-[-0.03em] text-transparent"
      set:html={title}
    />
    {tagline && (
      <p
        class="mx-auto mt-6 max-w-[40rem] text-[1rem] leading-relaxed text-muted"
        set:html={tagline}
      />
    )}

    {actions.length > 0 && (
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        {actions.map((action) => (
          <a
            href={action.link}
            class={`dux-btn ${action.variant === 'primary' ? 'dux-btn--primary' : 'dux-btn--ghost'}`}
            {...action.attrs}
          >
            <span>{action.text}</span>
            {action.variant === 'primary' && <span aria-hidden="true" class="dux-btn__arrow">→</span>}
          </a>
        ))}
      </div>
    )}

    <ul class="mt-8 flex list-none flex-wrap items-center justify-center gap-x-6 gap-y-2 p-0" aria-label={isZh ? '核心特性' : 'core principles'}>
      {pills.map((pill) => (
        <li class="inline-flex items-center gap-1.5 font-mono text-[0.8rem] tracking-[0.01em] text-muted">
          <span class="text-accent" aria-hidden="true">✓</span>
          {pill}
        </li>
      ))}
    </ul>
  </div>

  <div class="mx-auto mt-12 max-w-3xl">
    <div class="mb-4 flex justify-center">
      <div
        class="inline-flex max-w-full items-center gap-2.5 rounded-full border border-line bg-surface py-2 pl-4 pr-2 font-mono text-[0.85rem] text-ink"
        role="group"
        aria-label="install"
      >
        <span class="select-none text-accent" aria-hidden="true">$</span>
        <code class="overflow-x-auto whitespace-nowrap bg-transparent p-0">{installCmd}</code>
        <button
          type="button"
          class="dux-copy ml-1 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-muted transition-colors hover:bg-canvas hover:text-ink"
          data-copy={installCmd}
          aria-label={isZh ? '复制' : 'copy'}
        >
          <svg class="dux-copy__i h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
          <svg class="dux-copy__ok hidden h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
        </button>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-code-line bg-code">
      <div class="relative flex h-10 items-center border-b border-code-line bg-code-bar px-4">
        <span class="flex gap-2">
          <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
        </span>
        <span class="pointer-events-none absolute inset-x-0 text-center font-mono text-[0.78rem] text-[var(--dux-term-title)]">{fileName}</span>
      </div>
      <pre class="dux-hero-win m-0 overflow-x-auto px-6 py-5 text-left text-[0.85rem] leading-relaxed"><code class="font-mono" set:html={highlight(code)} /></pre>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.dux-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }
      const icon = btn.querySelector('.dux-copy__i');
      const ok = btn.querySelector('.dux-copy__ok');
      icon?.classList.add('hidden');
      ok?.classList.remove('hidden');
      window.setTimeout(() => {
        icon?.classList.remove('hidden');
        ok?.classList.add('hidden');
      }, 1400);
    });
  });
</script>
